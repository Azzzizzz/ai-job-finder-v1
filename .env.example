# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/ai-job-finder

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key
EMBEDDING_MODEL=text-embedding-3-large
REASONING_MODEL=gpt-4o

# Resend Configuration
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_TO_EMAIL=your_email@example.com

# Job Search Configuration
MIN_SIMILARITY_SCORE=0.75
TOP_JOBS_COUNT=15
FRESHNESS_DAYS=7
TARGET_COMPANIES=["Google", "Meta", "Netflix"] # Support JSON array or comma-separated string
TARGET_SOURCES=["linkedin", "weworkremotely", "workingnomads"] # Optional: Filter specific sources
TARGET_TITLES=["Senior Backend Engineer", "Backend Engineer", "Software Engineer"] # Optional: Override profile titles
